{
  "name": "paverate",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "wrangler types && vite build",
    "preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173 --live-reload --compatibility-date=2026-06-01 --compatibility-flag=nodejs_compat --ai AI",
    "preview:cloudflare": "npm run preview",
    "dev:cloudflare": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-cloudflare.ps1",
    "db:local": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1",
    "db:local:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1 -Reset",
    "db:migrate:remote": "wrangler d1 migrations apply paverate-db --remote",
    "db:migrate:list": "wrangler d1 migrations list paverate-db --remote",
    "db:pull-dev": "powershell -ExecutionPolicy Bypass -File ./scripts/db-pull-dev.ps1",
    "prepare": "svelte-kit sync || echo ''",
    "check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:components": "vitest run --project components",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run --project unit --coverage",
    "test:coverage:integration": "vitest run --project integration --coverage",
    "test:coverage:components": "vitest run --project components --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@turf/along": "^7.3.5",
    "@turf/buffer": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/line-offset": "^7.3.5",
    "@turf/line-slice": "^7.3.5",
    "@turf/nearest-point-on-line": "^7.3.5",
    "jspdf": "^2.5.2",
    "layerchart": "2.0.0-next.64",
    "lucide-svelte": "^1.0.1",
    "maplibre-gl": "^5.24.0",
    "pdfjs-serverless": "^1.2.3",
    "proj4": "^2.20.8"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-yaml": "^5.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "better-sqlite3": "^12.10.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.8",
    "wrangler": "^4.81.0"
  }
}

{
  "name": "paverate",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "wrangler types && vite build",
    "preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
    "db:local": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1",
    "db:local:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1 -Reset",
    "db:pull-dev": "powershell -ExecutionPolicy Bypass -File ./scripts/db-pull-dev.ps1",
    "prepare": "svelte-kit sync || echo ''",
    "check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen": "wrangler types"
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "kleur": "^4.1.5",
    "layerchart": "2.0.0-next.64",
    "leaflet": "^1.9.4",
    "lucide-svelte": "^1.0.1"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.0.3"
  },
  "devDependencies": {
    "@rollup/plugin-yaml": "^5.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "sharp": "^0.34.5",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "wrangler": "^4.81.0"
  }
}
